meta {
  name: Get Pokecoins (Obtener Pokecoins)
  type: http
  seq: 1
}

http {
  method: get
  url: {{baseUrl}}/coins/balance
}

headers {
  Authorization: Bearer {{token}}
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("Has coins", function() {
    expect(res.body.coins).to.be.a("number");
    bru.setVar("coins", res.body.coins);
  });
}
