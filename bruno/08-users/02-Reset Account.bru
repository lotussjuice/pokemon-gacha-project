meta {
  name: Reset Account (Reiniciar cuenta)
  type: http
  seq: 2
}

http {
  method: post
  url: {{baseUrl}}/users/reset
}

headers {
  Authorization: Bearer {{token}}
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("Has coins", function() {
    expect(res.body.coins).to.be.a("number");
  });
  test("Has message", function() {
    expect(res.body.message).to.be.a("string");
  });
}
