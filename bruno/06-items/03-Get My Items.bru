meta {
  name: Get My Items (Mi inventario)
  type: http
  seq: 3
}

http {
  method: get
  url: {{baseUrl}}/items/my
}

headers {
  Authorization: Bearer {{token}}
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("Is array", function() {
    expect(res.body).to.be.an("array");
  });
  test("Set first user item id", function() {
    if (res.body.length > 0) {
      bru.setVar("userItemId", res.body[0].id);
    }
  });
}
