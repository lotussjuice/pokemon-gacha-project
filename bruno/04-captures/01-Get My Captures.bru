meta {
  name: Get My Captures
  type: http
  seq: 1
}

http {
  method: get
  url: {{baseUrl}}/captures/my
}

headers {
  Authorization: Bearer {{token}}
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("Is array", function() {
    expect(res.body).to.be.an("array");
  });
  test("Set first capture id", function() {
    if (res.body.length > 0) {
      bru.setVar("captureId", res.body[0].id);
    }
  });
}
