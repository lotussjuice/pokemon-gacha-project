meta {
  name: 10 - Capture Direct
  type: http
  seq: 10
}

http {
  method: post
  url: {{baseUrl}}/captures/direct
  body: json
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  {
    "pokemonName": "pikachu"
  }
}

tests {
  test("Status 201", function() {
    expect(res.status).to.equal(201);
  });
  test("Has capture data", function() {
    expect(res.body.capture).to.be.an("object");
  });
}
