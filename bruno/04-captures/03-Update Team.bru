meta {
  name: Update Team (Actualizar equipo)
  type: http
  seq: 3
}

http {
  method: put
  url: {{baseUrl}}/captures/team
  body: json
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  {
    "teamIds": ["{{captureId}}"]
  }
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("Has team", function() {
    expect(res.body.team).to.be.an("array");
  });
}
